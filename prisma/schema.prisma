// DevQuest Empire - Prisma Schema
// 設計根拠: 19_Phase4_Implementation_Plan.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth (Auth.js) 標準モデル ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubLogin   String?   @unique

  accounts     Account[]
  sessions     Session[]
  player       Player?
  repositories GithubRepository[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- ドメインモデル ---

model Player {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  exp            Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime? @db.Date
  lastLoginBonusAt DateTime? @db.Date
  loginBonusStreak Int       @default(0)
  equippedTitleId  String?
  equippedTitle    TitleMaster? @relation("EquippedTitle", fields: [equippedTitleId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  village          Village?
  quests           Quest[]
  achievements     PlayerAchievement[]
  activityComments GithubActivityComment[]
  titles           PlayerTitle[]
  missionProgress  PlayerMissionProgress[]
  studyLogs        StudyLog[]
  qualifications   PlayerQualification[]
}

model TitleMaster {
  id              String @id @default(cuid())
  type            String @unique
  name            String
  condition       String
  unlockCondition Json

  playerTitles PlayerTitle[]
  equippedBy   Player[] @relation("EquippedTitle")
}

model PlayerTitle {
  id            String      @id @default(cuid())
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  titleMasterId String
  titleMaster   TitleMaster @relation(fields: [titleMasterId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([playerId, titleMasterId])
}

model GithubRepository {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  isPrivate      Boolean   @default(false)
  syncEnabled    Boolean   @default(false)
  privateConsent Boolean   @default(false)
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())

  commits      GithubCommit[]
  issues       GithubIssue[]
  pullRequests GithubPullRequest[]

  @@unique([userId, fullName])
}

model GithubCommit {
  id           String   @id @default(cuid())
  repositoryId String
  repository   GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  sha          String
  message      String
  committedAt  DateTime
  expAwarded   Int
  createdAt    DateTime @default(now())

  @@unique([repositoryId, sha])
}

model GithubIssue {
  id           String    @id @default(cuid())
  repositoryId String
  repository   GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  issueNumber  Int
  state        String
  closedAt     DateTime?
  expAwarded   Int
  createdAt    DateTime  @default(now())

  @@unique([repositoryId, issueNumber])
}

model GithubPullRequest {
  id           String    @id @default(cuid())
  repositoryId String
  repository   GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  prNumber     Int
  state        String
  mergedAt     DateTime?
  expAwarded   Int
  createdAt    DateTime  @default(now())

  @@unique([repositoryId, prNumber])
}

model Village {
  id       String @id @default(cuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  name     String @default("My Village")

  buildings VillageBuilding[]
}

model BuildingMaster {
  id          String @id @default(cuid())
  type        String @unique
  name        String
  description String
  metric      String // 建物の成長に使う指標(ActivityMetricsのキー)
  thresholds  Json // レベルごとの閾値の配列。例: [1,5,15,30,50] で最大Lv5
  sortOrder   Int    @default(0)

  buildings VillageBuilding[]
}

model FallbackQuest {
  id          String @id @default(cuid())
  title       String
  description String
  difficulty  String
}

model VillageBuilding {
  id               String   @id @default(cuid())
  villageId        String
  village          Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  buildingMasterId String
  buildingMaster   BuildingMaster @relation(fields: [buildingMasterId], references: [id])
  level            Int      @default(1)
  unlockedAt       DateTime @default(now())

  @@unique([villageId, buildingMasterId])
}

model Quest {
  id          String    @id @default(cuid())
  playerId    String
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  questDate   DateTime  @db.Date
  title       String
  description String
  difficulty  String
  expReward   Int
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([playerId, questDate])
}

model AchievementMaster {
  id        String @id @default(cuid())
  type      String @unique
  name      String
  condition String

  playerAchievements PlayerAchievement[]
}

model PlayerAchievement {
  id                  String   @id @default(cuid())
  playerId            String
  player              Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  achievementMasterId String
  achievementMaster   AchievementMaster @relation(fields: [achievementMasterId], references: [id])
  unlockedAt          DateTime @default(now())

  @@unique([playerId, achievementMasterId])
}

model MissionMaster {
  id          String @id @default(cuid())
  type        String @unique
  name        String
  description String
  period      String // "daily" | "weekly"
  metric      String // "commitCount" | "issueCloseCount" | "prOpenCount" | "prMergeCount"
  targetValue Int
  expReward   Int

  progress PlayerMissionProgress[]
}

model PlayerMissionProgress {
  id              String    @id @default(cuid())
  playerId        String
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  missionMasterId String
  missionMaster   MissionMaster @relation(fields: [missionMasterId], references: [id])
  periodKey       String
  claimedAt       DateTime?

  @@unique([playerId, missionMasterId, periodKey])
}

model StudyLog {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  category    String
  title       String
  minutes     Int
  note        String?
  expAwarded  Int
  recordedAt  DateTime
  createdAt   DateTime @default(now())
}

model QualificationMaster {
  id       String @id @default(cuid())
  type     String @unique
  name     String
  category String

  playerQualifications PlayerQualification[]
}

model PlayerQualification {
  id                    String    @id @default(cuid())
  playerId              String
  player                Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  qualificationMasterId String
  qualificationMaster   QualificationMaster @relation(fields: [qualificationMasterId], references: [id])
  status                String    @default("planning") // "planning" | "passed"
  examDate              DateTime? @db.Date
  passedDate            DateTime? @db.Date
  memo                  String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([playerId, qualificationMasterId])
}

model GithubActivityComment {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  commentDate DateTime @db.Date
  comment     String
  createdAt   DateTime @default(now())

  @@unique([playerId, commentDate])
}
