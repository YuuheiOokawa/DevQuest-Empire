# PostgreSQL接続文字列
DATABASE_URL="postgresql://user:password@localhost:5432/devquest_empire?schema=public"

# Auth.js (NextAuth v5)
AUTH_URL="http://localhost:4000"
# `openssl rand -base64 32` などで生成
AUTH_SECRET=""

# GitHub OAuth App (https://github.com/settings/developers で作成)
# ログインしたユーザー自身のアクセストークンをGitHub REST API呼び出しに使うため、
# 別途Personal Access Tokenなどを用意する必要はない(無料枠のみで動作する)。
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Claude API (今日のクエスト生成・活動コメント生成用)
ANTHROPIC_API_KEY=""
